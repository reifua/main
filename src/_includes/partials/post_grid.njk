{% from "macros/placeholder_img.njk" import placeholderImg %}

{% for post in paged.posts %}
  {% set typeConfig = property_types[post.data.propertyType] or {} %}
  {% set cardCfg = typeConfig.card or {} %}
  {% set primary = cardCfg.primary or [] %}
  {% set secondary = cardCfg.secondary or [] %}
    <div class="postcard">
        <div class="rounded shadow-lg h-full bg-gray-50 hover:shadow-xl">
            <a href="{{ post.url | url }}">
            {% if post.data.image %}
            <img
            class="w-full m-0 rounded-t lazy max-h-72 object-cover object-top card-thumbnail"
            src="{{ post.data.image | url }}"
            width="960"
            height="500"
            alt="{{ post.data.title | default('') }}">
            {% else %}
            {{ placeholderImg(post) }}
            {% endif %}
            </a>
            <div class="px-6 py-5">
                <div class="font-semibold text-lg mb-2">
                    <a class="text-gray-900 hover:text-gray-700" href="{{ post.url | url }}">{{ post.data.title }}</a>
                </div>
                <div class="text-xl font-bold text-teal-700 mb-2">{{ post.data.price | default("?") }} грн/міс</div>
                <div class="my-5 flex flex-wrap justify-between">
                    <p class="text-gray-700 mb-1 max-w-2/5">
                    {%- set parts = [] -%}
                    {%- for fn in primary -%}
                      {%- set val = post.data[fn] -%}
                      {%- if val != null and val !== "" -%}
                        {%- set fld = fields_schema.fields[fn] -%}
                        {%- if fld.render === "translated" -%}{% set parts = (parts.push(val | t + (fld.suffix or "")), parts) %}
                        {%- elseif fld.render === "boolean" -%}{% set parts = (parts.push("Так" if val else "Ні"), parts) %}
                        {%- elseif fld.render === "number" and fld.suffix -%}{% set parts = (parts.push(val + fld.suffix), parts) %}
                        {%- else -%}{% set parts = (parts.push(val), parts) %}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {{ parts | join(" · ") or "—" }}
                    </p>
                    <p class="text-gray-700 mb-1 max-w-3/5 break-words text-right">
                    {%- set parts = [] -%}
                    {%- for fn in secondary -%}
                      {%- set val = post.data[fn] -%}
                      {%- if val != null and val !== "" -%}
                        {%- set fld = fields_schema.fields[fn] -%}
                        {%- if fld.render === "translated" -%}{% set parts = (parts.push(val | t + (fld.suffix or "")), parts) %}
                        {%- elseif fld.render === "boolean" -%}{% set parts = (parts.push("Так" if val else "Ні"), parts) %}
                        {%- elseif fld.render === "number" and fld.suffix -%}{% set parts = (parts.push(val + fld.suffix), parts) %}
                        {%- else -%}{% set parts = (parts.push(val), parts) %}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {{ parts | join(" · ") or "—" }}
                    </p>
                </div>
                {% if post.data.summary -%}
                    {% if post.data.summary | isArray %}
                        <ul class="list-disc">
                        {% for bulletpoint in post.data.summary %}
                            <li>{{ bulletpoint }}</li>
                        {% endfor %}
                        </ul>
                    {% else %}
                        <p>{{ post.data.summary }}<p>
                    {% endif %}
                {%- endif %}
            </div>
        </div>
    </div>
{% endfor %}
