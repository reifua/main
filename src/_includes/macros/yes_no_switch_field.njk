{% macro YesNo(legend, name) %}
<fieldset class="flex flex-col">
    <legend>{{ legend }}</legend>
        <label class="inline-flex mt-3">
            <input type="radio" name="{{ name }}" value="true" onclick="updatePostGrid(this)" class="rental-filter form-radio h-5 w-5 text-gray-600">
            <span class="ml-2 text-gray-700">Так</span>
        </label>

        <label class="inline-flex mt-3">
            <input type="radio" name="{{ name }}" value="false" onclick="updatePostGrid(this)" class="rental-filter form-radio h-5 w-5 text-gray-600">
            <span class="ml-2 text-gray-700">Ні</span>
        </label>
</fieldset>
{% endmacro %}
