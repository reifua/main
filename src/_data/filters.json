{
  "fields": [
    {
      "name": "price",
      "label": "Орендна плата (грн/міс)",
      "type": "range",
      "min": 1000,
      "max": 200000,
      "step": 1000,
      "startMin": 1000,
      "startMax": 200000,
      "pipsStep": 50000,
      "showIf": ["*"]
    },
    {
      "name": "propertyType",
      "label": "Тип",
      "type": "radio",
      "dataSource": "propertyType",
      "showIf": ["*"]
    },
    {
      "name": "administrativeArea",
      "label": "Населений пункт",
      "type": "select",
      "dataSource": "administrativeArea",
      "showIf": ["*"]
    },
    {
      "name": "bedrooms",
      "label": "Кімнат",
      "type": "select",
      "dataSource": "bedrooms",
      "showIf": ["house", "apartment"]
    },
    {
      "name": "bathrooms",
      "label": "Ванних",
      "type": "select",
      "dataSource": "bathrooms",
      "showIf": ["house", "apartment"]
    },
    {
      "name": "area",
      "label": "Площа (м²)",
      "type": "range",
      "min": 200,
      "max": 5000,
      "step": 50,
      "startMin": 200,
      "startMax": 5000,
      "pipsStep": 500,
      "showIf": ["house", "apartment"]
    },
    {
      "name": "leaseTerm",
      "label": "Термін оренди",
      "type": "radio",
      "options": ["monthly", "yearly", "flexible"],
      "showIf": ["house", "apartment", "vehicle", "equipment"]
    },
    {
      "name": "furnished",
      "label": "Мебльовано",
      "type": "yesno",
      "showIf": ["house", "apartment"]
    },
    {
      "name": "petsAllowed",
      "label": "З тваринами",
      "type": "checkbox",
      "showIf": ["house", "apartment"]
    },
    {
      "name": "parking",
      "label": "Парковка",
      "type": "checkbox",
      "showIf": ["house", "apartment"]
    },
    {
      "name": "laundry",
      "label": "Прання",
      "type": "multiselect",
      "dataSource": "laundry",
      "showIf": ["house", "apartment"]
    },
    {
      "name": "hasAC",
      "label": "Кондиціонер",
      "type": "checkbox",
      "showIf": ["house", "apartment"]
    },
    {
      "name": "hasElevator",
      "label": "Ліфт",
      "type": "checkbox",
      "showIf": ["apartment"]
    },
    {
      "name": "balcony",
      "label": "Балкон",
      "type": "checkbox",
      "showIf": ["apartment"]
    },
    {
      "name": "hasGym",
      "label": "Спортзал",
      "type": "checkbox",
      "showIf": ["apartment"]
    },
    {
      "name": "hasPool",
      "label": "Басейн",
      "type": "checkbox",
      "showIf": ["apartment"]
    },
    {
      "name": "permittedUse",
      "label": "Цільове призначення",
      "type": "select",
      "dataSource": "permittedUse",
      "showIf": ["land"]
    },
    {
      "name": "make",
      "label": "Марка",
      "type": "select",
      "dataSource": "make",
      "showIf": ["vehicle", "equipment"]
    },
    {
      "name": "model",
      "label": "Модель",
      "type": "select",
      "dataSource": "model",
      "showIf": ["vehicle", "equipment"]
    },
    {
      "name": "year",
      "label": "Рік",
      "type": "select",
      "dataSource": "year",
      "showIf": ["vehicle", "equipment"]
    },
    {
      "name": "mileage",
      "label": "Пробіг (км)",
      "type": "range",
      "min": 0,
      "max": 200000,
      "step": 5000,
      "startMin": 0,
      "startMax": 200000,
      "pipsStep": 50000,
      "showIf": ["vehicle"]
    },
    {
      "name": "fuelType",
      "label": "Паливо",
      "type": "radio",
      "dataSource": "fuelType",
      "showIf": ["vehicle"]
    },
    {
      "name": "transmission",
      "label": "Коробка передач",
      "type": "radio",
      "options": ["automatic", "manual"],
      "showIf": ["vehicle"]
    },
    {
      "name": "seats",
      "label": "Місць",
      "type": "select",
      "dataSource": "seats",
      "showIf": ["vehicle"]
    },
    {
      "name": "equipmentType",
      "label": "Тип обладнання",
      "type": "select",
      "dataSource": "equipmentType",
      "showIf": ["equipment"]
    },
    {
      "name": "condition",
      "label": "Стан",
      "type": "radio",
      "options": ["new", "excellent", "good", "fair"],
      "showIf": ["equipment"]
    },
    {
      "name": "weight",
      "label": "Вага (кг)",
      "type": "range",
      "min": 0,
      "max": 20000,
      "step": 100,
      "startMin": 0,
      "startMax": 20000,
      "pipsStep": 5000,
      "showIf": ["equipment"]
    },
    {
      "name": "availableNow",
      "label": "Доступно зараз",
      "type": "yesno",
      "showIf": ["*"]
    }
  ]
}
